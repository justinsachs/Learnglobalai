# LearnGlobal.ai Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Application Settings
# ===========================================
NODE_ENV=development
LOG_LEVEL=debug
API_PORT=3000
API_HOST=0.0.0.0
ADMIN_UI_PORT=3001

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://learnglobal:learnglobal_dev@localhost:5432/learnglobal
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ===========================================
# Redis (for BullMQ job queue)
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===========================================
# Object Storage (S3-compatible / MinIO)
# ===========================================
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=learnglobal-assets
STORAGE_REGION=us-east-1

# ===========================================
# LLM Provider (OpenAI)
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3

# ===========================================
# NotebookLM Enterprise (Google)
# ===========================================
NOTEBOOKLM_ENABLED=false
NOTEBOOKLM_API_URL=https://notebooklm.googleapis.com/v1
NOTEBOOKLM_PROJECT_ID=your-gcp-project-id
NOTEBOOKLM_SERVICE_ACCOUNT_KEY=path/to/service-account.json

# ===========================================
# HeyGen Video Generation
# ===========================================
HEYGEN_ENABLED=false
HEYGEN_API_KEY=your-heygen-api-key
HEYGEN_API_URL=https://api.heygen.com/v2
HEYGEN_WEBHOOK_URL=http://your-domain.com/webhooks/heygen
HEYGEN_DEFAULT_AVATAR_ID=
HEYGEN_DEFAULT_VOICE_ID=

# ===========================================
# LMS Integration
# ===========================================
LMS_PROVIDER=filesystem
LMS_OUTPUT_PATH=./lms-output
# For real LMS providers:
# LMS_PROVIDER=canvas
# LMS_API_URL=https://your-lms.instructure.com/api/v1
# LMS_API_KEY=your-lms-api-key

# ===========================================
# Authentication / Security
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
API_KEY_HASH_SALT=random-salt-for-api-keys
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# ===========================================
# Vector Store (for RAG/Chat)
# ===========================================
VECTOR_STORE_PROVIDER=pgvector
# For external providers:
# VECTOR_STORE_PROVIDER=pinecone
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENVIRONMENT=us-west1-gcp

# ===========================================
# Feature Flags
# ===========================================
FEATURE_NOTEBOOKLM=false
FEATURE_HEYGEN=false
FEATURE_LMS_PUBLISH=true
FEATURE_CHAT=true
FEATURE_APPROVAL_REQUIRED=false

# ===========================================
# Quality Gate Thresholds
# ===========================================
QA_MIN_TOTAL_WORDS=5000
QA_MIN_WORDS_PER_HEADING=500
QA_MAX_BULLET_RATIO=0.08
QA_REQUIRE_DISCLAIMERS=true

# ===========================================
# Observability
# ===========================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=learnglobal-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
METRICS_ENABLED=true
METRICS_PORT=9090
