{
  "name": "@learnglobal/api",
  "version": "1.0.0",
  "description": "LearnGlobal.ai API Server",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run --dir src",
    "test:integration": "vitest run --dir tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:create": "tsx src/db/create-migration.ts",
    "seed": "tsx src/db/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@learnglobal/contracts": "workspace:*",
    "@learnglobal/orchestrator": "workspace:*",
    "@learnglobal/connectors": "workspace:*",
    "@learnglobal/llm": "workspace:*",
    "@learnglobal/chat": "workspace:*",
    "fastify": "^4.24.0",
    "@fastify/cors": "^8.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/swagger": "^8.12.0",
    "@fastify/swagger-ui": "^2.0.0",
    "drizzle-orm": "^0.29.0",
    "postgres": "^3.4.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0",
    "dotenv": "^16.3.1",
    "nanoid": "^5.0.0",
    "crypto-js": "^4.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/crypto-js": "^4.2.0",
    "typescript": "^5.3.0",
    "tsx": "^4.6.0",
    "vitest": "^1.0.0",
    "drizzle-kit": "^0.20.0"
  }
}
